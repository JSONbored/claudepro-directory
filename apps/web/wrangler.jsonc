{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "heyclaude-prod",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-05",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  },
  "logpush": true,
  "placement": {
    "mode": "smart"
  },
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "heyclaude-prod"
    }
  ],
  "d1_databases": [
    {
      "binding": "VOTES_DB",
      "database_name": "heyclaude-votes",
      "database_id": "2897db33-c0c7-4d15-af73-618cb83a0a33",
      "migrations_dir": "migrations"
    }
  ],
  "env": {
    "dev": {
      "name": "heyclaude-dev",
      "services": [
        {
          "binding": "WORKER_SELF_REFERENCE",
          "service": "heyclaude-dev"
        }
      ],
      "d1_databases": [
        {
          "binding": "VOTES_DB",
          "database_name": "heyclaude-votes",
          "database_id": "2897db33-c0c7-4d15-af73-618cb83a0a33",
          "migrations_dir": "migrations"
        }
      ]
    }
  }
}
