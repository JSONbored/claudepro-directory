{
  "name": "web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "node ../../scripts/build-content-index.mjs",
    "prebuild": "node ../../scripts/build-content-index.mjs",
    "pretype-check": "node ../../scripts/build-content-index.mjs && next typegen",
    "prepreview": "node ../../scripts/build-content-index.mjs",
    "predeploy": "node ../../scripts/build-content-index.mjs",
    "predeploy:dev": "node ../../scripts/build-content-index.mjs",
    "predeploy:prod": "node ../../scripts/build-content-index.mjs",
    "dev": "next dev",
    "build": "next build",
    "type-check": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv worker-configuration.d.ts",
    "db:migrate:local": "wrangler d1 migrations apply SITE_DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply SITE_DB --remote",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:dev": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --env dev",
    "deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@heyclaude/registry": "workspace:*",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fflate": "0.8.2",
    "geist": "1.7.0",
    "lucide-react": "1.8.0",
    "marked": "18.0.0",
    "next": "16.2.3",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "0.0.1",
    "svix": "1.92.2",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "postcss": "8.5.12",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.2",
    "wrangler": "4.81.1"
  }
}
