{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "heyclaude-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],
  
  // Base configuration (shared across all environments)
  // Note: Top-level config serves as defaults, but environments override
  
  // Development Environment (Feature Branch)
  "env": {
    "dev": {
      "name": "heyclaude-mcp-dev",
      "routes": [
        {
          "pattern": "dev.claudepro.directory/mcp*",
          "zone_name": "claudepro.directory"
        },
        {
          "pattern": "dev.claudepro.directory/.well-known/oauth*",
          "zone_name": "claudepro.directory"
        },
        {
          "pattern": "dev.claudepro.directory/oauth/*",
          "zone_name": "claudepro.directory"
        }
      ],
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "62623dcc591041fb99251ec7832aeea6"
        }
      ],
      "ratelimits": [
        {
          "name": "MCP_RATE_LIMITER_DEV",
          "namespace_id": "1001",
          "simple": {
            "limit": 200,
            "period": 60
          }
        }
      ],
      "secrets_store_secrets": [
        {
          "binding": "INFISICAL_CLIENT_ID_SECRET",
          "store_id": "8d2dcc4d5db1415e91e14a487baf6b0a",
          "secret_name": "INFISICAL_CLIENT_ID"
        },
        {
          "binding": "INFISICAL_CLIENT_SECRET_SECRET",
          "store_id": "8d2dcc4d5db1415e91e14a487baf6b0a",
          "secret_name": "INFISICAL_CLIENT_SECRET"
        }
      ],
      "vars": {
        "NODE_ENV": "development",
        "NEXT_PUBLIC_SITE_URL": "https://dev.claudepro.directory",
        "APP_URL": "https://dev.claudepro.directory",
        "MCP_SERVER_URL": "https://dev.claudepro.directory",
        "INFISICAL_ENV": "dev" // Explicitly set to 'dev' for dev environment
      },
      "kv_namespaces": [
        {
          "binding": "MCP_CACHE",
          "id": "8976c9eba1c84e5cb8993041442cc60a"
        }
      ],
      "analytics_engine_datasets": [
        {
          "binding": "MCP_ANALYTICS",
          "dataset": "mcp_analytics_dev"
        }
      ]
    },
    
    // Production Environment (Main Branch)
    "production": {
      "name": "heyclaude-mcp-production",
      "routes": [
        {
          "pattern": "mcp.claudepro.directory/*",
          "zone_name": "claudepro.directory"
        }
      ],
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "YOUR_HYPERDRIVE_PRODUCTION_CONFIG_ID"
        }
      ],
      "ratelimits": [
        {
          "name": "MCP_RATE_LIMITER_PROD",
          "namespace_id": "1001",
          "simple": {
            "limit": 100,
            "period": 60
          }
        }
      ],
      "secrets_store_secrets": [
        {
          "binding": "INFISICAL_CLIENT_ID_SECRET",
          "store_id": "8d2dcc4d5db1415e91e14a487baf6b0a",
          "secret_name": "INFISICAL_CLIENT_ID"
        },
        {
          "binding": "INFISICAL_CLIENT_SECRET_SECRET",
          "store_id": "8d2dcc4d5db1415e91e14a487baf6b0a",
          "secret_name": "INFISICAL_CLIENT_SECRET"
        }
      ],
      "vars": {
        "NODE_ENV": "production",
        "NEXT_PUBLIC_SITE_URL": "https://claudepro.directory",
        "APP_URL": "https://claudepro.directory",
        "INFISICAL_ENV": "prod" // Explicitly set to 'prod' for production environment
      },
      "kv_namespaces": [
        {
          "binding": "MCP_CACHE",
          "id": "37ddde925d114bb0bd49e81294b79fcc"
        }
      ],
      "analytics_engine_datasets": [
        {
          "binding": "MCP_ANALYTICS",
          "dataset": "mcp_analytics_prod"
        }
      ]
    }
  }
}
