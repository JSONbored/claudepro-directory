          "category": {
            "description": "Content category",
            "example": "agents",
            "type": "string",
            "enum": [
              "agents",
              "rules",
              "commands",
              "skills",
              "collections",
              "mcp",
              "hooks",
              "statuslines",
              "guides",
              "jobs",
              "changelog"
