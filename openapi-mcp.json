            "enum": [
              "agents",
              "rules",
              "commands",
              "skills",
              "collections",
              "mcp",
              "hooks",
              "statuslines",
              "guides",
              "jobs",
              "changelog"
            ]
          }
        },
        "description": "Get content submission templates for creating new content. Includes field definitions, requirements, and examples.",
        "example": {
          "category": ""
        }
      },
      "getCategoryConfigsInput": {
        "type": "object",
        "properties": {
          "category": {
            "description": "Filter by specific category (optional)",
            "example": "agents",
            "type": "string",
            "enum": [
              "agents",
              "rules",
              "commands",
              "skills",
              "collections",
              "mcp",
              "hooks",
              "statuslines",
              "guides",
              "jobs",
              "changelog"
            ]
          }
        },
        "description": "Get category-specific configurations and features. Helps understand category-specific requirements and submission guidelines.",
        "example": {
          "category": ""
        }
      },
      "getChangelogInput": {
        "type": "object",
        "properties": {
          "format": {
            "description": "Output format (default: llms-txt)",
            "example": "llms-txt",
            "default": "llms-txt",
            "type": "string",
            "enum": [
              "llms-txt",
              "json"
            ]
          }
        },
        "description": "Get changelog of content updates in LLMs.txt format. Helps AI agents understand recent changes and stay current.",
        "example": {
