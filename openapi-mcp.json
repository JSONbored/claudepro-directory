            "format": "path",
            "type": "string"
          }
        },
        "required": [
          "category",
          "slug"
        ],
        "description": "Download content formatted for a specific platform (Claude Code, Cursor, ChatGPT Codex, or generic). Returns formatted content with installation instructions.",
        "example": {
          "category": "",
          "slug": "example",
          "platform": "",
          "targetDirectory": "example"
        }
      },
      "getSocialProofStatsInput": {
