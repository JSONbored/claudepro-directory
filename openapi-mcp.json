        "example": {
          "tags": [],
          "logic": "",
          "category": "",
          "limit": 0
        }
      },
      "downloadContentForPlatformInput": {
        "type": "object",
        "properties": {
          "category": {
            "description": "Content category",
            "example": "agents",
            "type": "string",
            "enum": [
              "agents",
              "rules",
              "commands",
              "skills",
              "collections",
              "mcp",
              "hooks",
              "statuslines",
              "guides",
              "jobs",
              "changelog"
            ]
          },
