        "description": "Get popular content across categories or within a specific category. Sorted by views and engagement metrics.",
        "example": {
          "category": "",
          "limit": 0
        }
      },
      "getRecentInput": {
        "type": "object",
        "properties": {
          "category": {
            "description": "Filter by category (optional)",
            "example": "agents",
            "type": "string",
            "enum": [
              "agents",
              "rules",
