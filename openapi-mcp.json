              "agents",
              "mcp",
              "rules",
              "commands",
              "hooks",
              "statuslines",
              "skills"
            ]
          },
          "category": {
            "description": "Content category (usually matches submission_type)",
            "example": "agents",
            "type": "string",
            "enum": [
              "agents",
              "rules",
              "commands",
              "skills",
              "collections",
              "mcp",
              "hooks",
              "statuslines",
              "guides",
              "jobs",
              "changelog"
            ]
          },
          "name": {
            "description": "Title/name of the content (required)",
            "example": "AI Agent Framework",
            "type": "string"
          },
          "description": {
            "description": "Brief description of the content (required)",
