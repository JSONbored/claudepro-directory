          "category": "",
          "name": "example",
          "description": "example",
          "author": "example",
          "content_data": null,
          "author_profile_url": "example",
          "github_url": "example",
          "tags": []
        }
      },
      "createAccountInput": {
        "type": "object",
        "properties": {
          "provider": {
            "description": "OAuth provider to use for account creation (default: \"github\")",
            "example": "github",
            "default": "github",
            "type": "string",
