            "type": "string"
          },
          "limit": {
            "description": "Number of suggestions to return (1-20, default: 10)",
            "example": 10,
            "minimum": 1,
            "maximum": 20,
            "default": 10,
            "type": "integer"
          }
        },
        "required": [
          "query"
        ],
