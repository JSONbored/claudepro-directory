generator client {
  provider = "prisma-client"
  output   = "../packages/database-types/src/prisma"
  engineType = "client"
  moduleFormat = "esm"
  previewFeatures = ["relationJoins"]
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../packages/database-types/src/prisma/zod"
}

generator json-types {
  provider  = "prisma-json-types-generator"
  namespace = "PrismaJson"
  allowAny  = false
  output    = "../packages/database-types/src/prisma/json-types"
}

generator postgres-types {
  provider = "./packages/generators/src/prisma-postgres-types-generator/index.ts"
  output   = "../packages/database-types/src/postgres-types"
  schema   = "public"
  generateTypes = true
  generateZod = true
  // Exclude composite types that conflict with Prisma model types
  // These composite types have string dates, while Prisma models have Date objects
  excludeCompositeTypes = ["announcements", "content", "jobs", "notifications"]
}

generator openapi {
  provider = "prisma-openapi"
  output   = "../packages/database-types/src/openapi"
}

generator docs {
  provider = "node node_modules/.pnpm/prisma-docs-generator@0.8.0/node_modules/prisma-docs-generator/dist/index.js"
  output   = "../packages/database-types/docs"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "public"]
}

