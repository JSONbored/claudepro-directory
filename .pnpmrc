# pnpm configuration
# Allow specific packages to run lifecycle scripts (pnpm v9+)
lifecycle-scripts-allow-list[]=sharp
lifecycle-scripts-allow-list[]=esbuild
lifecycle-scripts-allow-list[]=msw
lifecycle-scripts-allow-list[]=lefthook

# Hoist Next.js and React to root for type compatibility
# This ensures all packages use the same Next.js installation
# Fixes TypeScript type compatibility issues in monorepo
# See PNPM_HOISTING_EXPLANATION.md for details
public-hoist-pattern[]=next
public-hoist-pattern[]=react
public-hoist-pattern[]=react-dom
# Hoist @prisma/client for Prismock compatibility
# Prismock needs to resolve @prisma/client internally, and pnpm's virtual store
# prevents this resolution. Hoisting ensures Prismock can find @prisma/client.
public-hoist-pattern[]=@prisma/client
