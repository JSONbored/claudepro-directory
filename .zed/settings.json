{
  "typescript": {
    "tsconfig": "tsconfig.json"
  },
  "deno": {
    "enable": true,
    "config": "./apps/edge/functions/deno.json",
    "lint": true,
    "unstable": true,
    "internal_debug": false
  },
  "format_on_save": "on",
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": false,
    "edit_debounce_ms": 700,
    "scroll_debounce_ms": 50
  },
  "languages": {
    "Deno": {
      "language_servers": ["deno", "!typescript-language-server", "!vtsls"]
    },
    "TypeScript": {
      "language_servers": ["vtsls", "typescript-language-server", "ast-grep", "!deno"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "npx",
            "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
          }
        }
      ]
    },
    "JavaScript": {
      "language_servers": ["vtsls", "typescript-language-server", "ast-grep", "!deno"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "npx",
            "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
          }
        }
      ]
    },
    "TypeScript React": {
      "language_servers": ["vtsls", "typescript-language-server", "ast-grep", "!deno"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "npx",
            "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
          }
        }
      ]
    },
    "JavaScript React": {
      "language_servers": ["vtsls", "typescript-language-server", "ast-grep", "!deno"],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint"
        },
        {
          "external": {
            "command": "npx",
            "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"]
          }
        }
      ]
    },
    "CSS": {
      "language_servers": ["eslint", "tailwindcss"],
      "formatter": ["npx", "prettier", "--stdin-filepath"]
    },
    "JSON": {
      "language_servers": ["eslint"],
      "formatter": ["npx", "prettier", "--stdin-filepath"]
    },
    "Markdown": {
      "language_servers": ["eslint"],
      "formatter": ["npx", "prettier", "--stdin-filepath"]
    },
    "HTML": {
      "language_servers": ["eslint"]
    },
    "YAML": {
      "language_servers": ["eslint"]
    }
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "tsdk": "./node_modules/typescript/lib",
          "preferences": {
            "includePackageJsonAutoImports": "on"
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        },
        "javascript": {
          "preferences": {
            "includePackageJsonAutoImports": "on"
          },
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": false
            },
            "parameterTypes": {
              "enabled": true
            },
            "variableTypes": {
              "enabled": true,
              "suppressWhenTypeMatchesName": true
            },
            "propertyDeclarationTypes": {
              "enabled": true
            },
            "functionLikeReturnTypes": {
              "enabled": true
            },
            "enumMemberValues": {
              "enabled": true
            }
          }
        }
      }
    },
    "typescript-language-server": {
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": true,
          "includeInlayVariableTypeHints": true,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": true,
          "includeInlayPropertyDeclarationTypeHints": true,
          "includeInlayFunctionLikeReturnTypeHints": true,
          "includeInlayEnumMemberValueHints": true
        }
      },
      "settings": {
        "typescript": {
          "tsdk": "./node_modules/typescript/lib",
          "preferences": {
            "includePackageJsonAutoImports": "on"
          }
        },
        "javascript": {
          "preferences": {
            "includePackageJsonAutoImports": "on"
          }
        }
      }
    },
    "deno": {
      "settings": {
        "deno": {
          "enable": true,
          "config": "./apps/edge/functions/deno.json",
          "lint": true,
          "unstable": true
        }
      }
    },
    "eslint": {
      "settings": {
        "codeActionOnSave": {
          "enable": true,
          "mode": "all"
        },
        "validate": [
          "typescript",
          "typescriptreact",
          "javascript",
          "javascriptreact",
          "html",
          "css",
          "json",
          "jsonc",
          "markdown",
          "yaml"
        ],
        "run": "onType"
      }
    },
    "tailwindcss": {
      "binary": {
        "path": "npx",
        "arguments": ["@tailwindcss/language-server"]
      },
      "initialization_options": {
        "experimental": {
          "classRegex": [
            ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
            ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^\"'`]*)(?:'|\"|`)"]
          ]
        },
        "userLanguages": {
          "typescript": "javascript",
          "typescriptreact": "javascriptreact"
        }
      }
    },
    "ast-grep": {
      "binary": {
        "path": "ast-grep",
        "arguments": ["lsp"]
      }
    },
    "discord_presence": {
      "initialization_options": {
        "application_id": "1263505205522337886",
        "base_icons_url": "https://raw.githubusercontent.com/xhyrom/zed-discord-presence/main/assets/icons/",
        "state": "Building heyclau.de: {folder_and_file}",
        "details": "Claude Pro Directory • {workspace}",
        "large_image": "{base_icons_url}/{language:lo}.png",
        "large_text": "{language:u}",
        "small_image": "{base_icons_url}/zed.png",
        "small_text": "Zed",
        "idle": {
          "timeout": 300,
          "action": "change_activity",
          "state": "Taking a break from heyclau.de",
          "details": "Claude Pro Directory • Idling",
          "large_image": "{base_icons_url}/zed.png",
          "large_text": "Zed",
          "small_image": "{base_icons_url}/idle.png",
          "small_text": "Coffee break ☕"
        },
        "git_integration": true,
        "languages": {
          "typescript": {
            "state": "TypeScript wizardry: {folder_and_file}",
            "details": "Building Claude Pro Directory",
            "large_text": "TypeScript"
          },
          "javascript": {
            "state": "JS magic: {folder_and_file}",
            "details": "Claude Pro Directory",
            "large_text": "JavaScript"
          },
          "typescriptreact": {
            "state": "React + TS: {folder_and_file}",
            "details": "Claude Pro Directory UI",
            "large_text": "React + TypeScript"
          },
          "javascriptreact": {
            "state": "React component: {folder_and_file}",
            "details": "Claude Pro Directory",
            "large_text": "React"
          },
          "markdown": {
            "state": "Documenting: {filename}",
            "details": "Claude Pro Directory docs",
            "large_text": "Documentation"
          },
          "yaml": {
            "state": "Config: {filename}",
            "details": "Claude Pro Directory setup",
            "large_text": "Configuration"
          },
          "json": {
            "state": "Config: {filename}",
            "details": "Claude Pro Directory",
            "large_text": "JSON"
          },
          "css": {
            "state": "Styling: {filename}",
            "details": "Claude Pro Directory",
            "large_text": "CSS"
          }
        }
      }
    }
  }
}
