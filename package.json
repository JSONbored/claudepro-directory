{
  "name": "claudepro-directory",
  "private": true,
  "sideEffects": false,
  "version": "1.1.0",
  "description": "A community-driven directory of Claude configurations including agents, MCP servers, rules, commands, and hooks",
  "author": "JSONbored",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JSONbored/claudepro-directory"
  },
  "keywords": [
    "claude",
    "ai",
    "mcp",
    "agents",
    "configurations",
    "directory"
  ],
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:generate:exec": "infisical run --env=dev --recursive -- sh -c 'prisma generate && tsx packages/generators/src/scripts/post-prisma-generate.ts'",
    "postgenerate": "tsx packages/generators/src/scripts/post-prisma-generate.ts",
    "generate:prismocker-enums": "tsx packages/generators/src/scripts/generate-prismocker-enums.ts",
    "generators:build": "pnpm --filter @heyclaude/generators build",
    "deploy:web": "vercel",
    "dev": "infisical run --env=dev -- turbo run dev:exec",
    "dev:clean": "rm -rf .turbo packages/*/dist packages/*/.tsbuildinfo && turbo run build --force --filter=@heyclaude/database-types --filter=@heyclaude/shared-runtime --filter=@heyclaude/data-layer --filter=@heyclaude/web-runtime && turbo run dev:exec",
    "dev:generators": "turbo run generate:service-worker:exec",
    "mcp:inspect": "mcp-inspector",
    "build": "pnpm build:sw && turbo run build --filter=web",
    "build:dev": "infisical run --env=dev --recursive -- sh -c 'pnpm build:sw && pnpm --filter web build --debug-prerender'",
    "build:force": "turbo run build --force",
    "build:clean": "rm -rf .turbo packages/*/dist packages/*/.tsbuildinfo && turbo run build --force",
    "build:analyze": "TURBOPACK_STATS=1 next build apps/web --turbopack",
    "build:sw": "tsx packages/generators/src/bin/minify-service-worker.ts",
    "analyze:bundle": "cd apps/web && ANALYZE=true pnpm build",
    "analyze:sourcemap": "cd apps/web && pnpm build && source-map-explorer '.next/static/chunks/*.js' --html",
    "analyze:deps": "depcheck",
    "lighthouse": "lhci autorun",
    "build:skills": "turbo run build:skills:exec",
    "build:skills:exec": "pnpm exec heyclaude-generate-skills",
    "build:mcpb": "turbo run build:mcpb:exec",
    "generate:service-worker": "turbo run generate:service-worker:exec",
    "generate:service-worker:exec": "pnpm exec heyclaude-generate-service-worker",
    "generate:openapi": "infisical run --env=dev -- pnpm exec heyclaude-generate-openapi",
    "generate:api-client": "turbo run generate:api-client:exec",
    "generate:api-client:exec": "pnpm exec heyclaude-generate-api-client",
    "generate:readme": "turbo run generate:readme:exec",
    "sync:db": "infisical run --env=dev -- pnpm exec heyclaude-sync-db --skip-dump",
    "sync:db:full": "infisical run --env=dev -- pnpm exec heyclaude-sync-db",
    "cache:info": "turbo run cache:info:exec",
    "cache:clear": "turbo run cache:clear:exec",
    "webhooks:replay": "turbo run webhooks:replay:exec",
    "changelog:generate": "turbo run changelog:generate:exec",
    "changelog:generate:dry": "turbo run changelog:generate:dry:exec",
    "changelog:generate:branch": "turbo run changelog:generate:branch:exec",
    "bump-version": "pnpm exec heyclaude-bump-version",
    "bump:major": "pnpm exec heyclaude-bump-version major",
    "bump:minor": "pnpm exec heyclaude-bump-version minor",
    "bump:patch": "pnpm exec heyclaude-bump-version patch",
    "start": "next start apps/web",
    "type-check": "echo '⏱️  Starting type-check...' && turbo run type-check && echo '✅ Type-check completed'",
    "type-check:build": "echo '⏱️  Starting build system type-check...' && turbo run type-check --filter=web --filter=@heyclaude/* --filter=@heyclaude/workers-heyclaude-mcp && echo '✅ Build system type-check completed'",
    "type-check:web": "turbo run type-check --filter=web",
    "type-check:packages": "turbo run type-check --filter=@heyclaude/*",
    "type-check:unused": "ts-prune",
    "type-check:unused:filtered": "turbo run type-check:unused:filtered:exec",
    "lint": "turbo run lint",
    "lint:build": "eslint --config config/tools/eslint.config.mjs --cache --cache-location .eslintcache packages/web-runtime/src/data apps/web/src/app --ignore-pattern '**/*.generated.ts' --ignore-pattern '**/*.generated.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.spec.ts' --ignore-pattern '**/*.spec.tsx'",
    "lint:build:fix": "eslint --config config/tools/eslint.config.mjs --cache --cache-location .eslintcache packages/web-runtime/src/data apps/web/src/app --ignore-pattern '**/*.generated.ts' --ignore-pattern '**/*.generated.tsx' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.test.tsx' --ignore-pattern '**/*.spec.ts' --ignore-pattern '**/*.spec.tsx' --fix",
    "lint:web": "turbo run lint --filter=web",
    "lint:packages": "turbo run lint --filter=@heyclaude/*",
    "lint:fix": "turbo run lint -- --fix",
    "lint:fix:web": "turbo run lint --filter=web -- --fix",
    "lint:fix:packages": "turbo run lint --filter=@heyclaude/* -- --fix",
    "analyze:dependencies": "pnpm exec heyclaude-analyze-dependencies",
    "validate:mcp": "pnpm analyze:dependencies",
    "validate:build": "pnpm type-check:build && pnpm lint:build",
    "test": "pnpm test:jest",
    "test:jest": "infisical run --env=dev -- jest --testPathIgnorePatterns='\\.spec\\.(ts|tsx)$'",
    "test:playwright": "pnpm exec playwright test",
    "test:all": "pnpm test:jest && pnpm test:playwright",
    "test:watch": "infisical run --env=dev -- jest --watch --testPathIgnorePatterns='\\.spec\\.(ts|tsx)$'",
    "test:coverage": "infisical run --env=dev -- jest --coverage --testPathIgnorePatterns='\\.spec\\.(ts|tsx)$'",
    "test:mcp-server": "jest --testPathPattern=config/tests/mcp-server",
    "test:mcp-server:watch": "jest --testPathPattern=config/tests/mcp-server --watch",
    "test:mcp-server:coverage": "jest --testPathPattern=config/tests/mcp-server --coverage",
    "test:visual": "playwright test --config config/tests/playwright.config.ts",
    "test:visual:ui": "playwright test --config config/tests/playwright.config.ts --ui",
    "test:visual:update": "playwright test --config config/tests/playwright.config.ts --update-snapshots",
    "test:visual:debug": "playwright test --config config/tests/playwright.config.ts --debug",
    "test:visual:report": "playwright show-report",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\" && pnpm lint:fix",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "email:dev": "email dev --dir packages/web-runtime/src/email/templates --port 3001",
    "dev:exec": "concurrently --names \"NEXT,INNGEST\" --prefix-colors \"blue,green\" \"next dev apps/web --turbopack\" \"pnpm exec inngest-cli dev\"",
    "build:mcpb:exec": "infisical run --env=dev -- pnpm exec heyclaude-generate-mcpb",
    "generate:readme:exec": "infisical run --env=dev -- pnpm exec heyclaude-generate-readme",
    "sync:db:exec": "infisical run --env=dev -- pnpm exec heyclaude-sync-db --skip-dump --skip-package-builds",
    "sync:db:full:exec": "infisical run --env=dev -- pnpm exec heyclaude-sync-db --skip-package-builds",
    "sync:db:neon:test": "cd .migration/neon-auth/sync-system && pnpm sync:types",
    "sync:db:neon:test:full": "cd .migration/neon-auth/sync-system && pnpm sync:full",
    "sync:db:neon:test:dump": "cd .migration/neon-auth/sync-system && pnpm sync:dump",
    "sync:db:neon:test:force": "cd .migration/neon-auth/sync-system && pnpm sync:force",
    "cache:info:exec": "pnpm exec heyclaude-cache info",
    "cache:clear:exec": "pnpm exec heyclaude-cache clear",
    "webhooks:replay:exec": "pnpm exec heyclaude-webhooks-replay",
    "changelog:generate:exec": "infisical run --env=dev -- pnpm exec heyclaude-changelog",
    "changelog:generate:dry:exec": "infisical run --env=dev -- pnpm exec heyclaude-changelog --dry-run",
    "changelog:generate:branch:exec": "infisical run --env=dev -- pnpm exec heyclaude-changelog --branch",
    "type-check:unused:filtered:exec": "pnpm exec heyclaude-lint-unused",
    "prepare": "command -v lefthook >/dev/null 2>&1 && lefthook install >/dev/null 2>&1 || echo 'Skipping lefthook install (not available)'",
    "analyze:architecture": "npx skott --displayMode=webapp",
    "analyze:unused": "infisical run --env=dev -- npx knip -c config/tools/knip.json",
    "analyze:circular": "npx madge --circular --extensions ts,tsx apps/web/src/",
    "analyze:circular-graph": "npx madge --circular --extensions ts,tsx --image circular-deps.svg apps/web/src/",
    "analyze:all": "npm run analyze:unused && npm run analyze:circular"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@faker-js/faker": "^9.3.0",
    "@heyclaude/generators": "workspace:*",
    "@inngest/eslint-plugin": "^0.0.7",
    "@jest/globals": "^30.2.0",
    "@lhci/cli": "^0.15.1",
    "@modelcontextprotocol/inspector": "^0.18.0",
    "@next/eslint-plugin-next": "^16.1.0",
    "@playwright/test": "^1.57.0",
    "@react-email/components": "^1.0.2",
    "@react-email/render": "^2.0.0",
    "@scalar/nextjs-api-reference": "^0.9.7",
    "@supabase/supabase-js": "^2.89.0",
    "@tailwindcss/language-server": "^0.14.29",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "archiver": "^7.0.1",
    "axe-core": "^4.10.0",
    "concurrently": "^9.2.1",
    "css-tree": "^3.1.0",
    "depcheck": "^1.4.7",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-github": "^1.1.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-array-func": "^5.1.0",
    "eslint-plugin-better-tailwindcss": "^3.8.0",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-de-morgan": "^2.0.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^29.10.1",
    "eslint-plugin-jsdoc": "^61.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-perfectionist": "^5.0.0",
    "eslint-plugin-playwright": "^2.4.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-testing-library": "^7.15.1",
    "eslint-plugin-turbo": "^2.7.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "imagemin": "^9.0.1",
    "imagemin-avif": "^0.1.6",
    "imagemin-webp": "^8.0.0",
    "inngest-cli": "^1.15.1",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "jest-openapi": "^0.14.2",
    "jsdom": "^27.3.0",
    "knip": "^5.76.1",
    "lefthook": "^2.0.12",
    "msw": "^2.7.0",
    "openapi-typescript": "^7.10.1",
    "openapi-zod-client": "^1.18.3",
    "ora": "^9.0.0",
    "playwright-html-reporter": "^0.1.11",
    "playwright-test-coverage": "^1.2.12",
    "postcss": "^8.5.6",
    "postcss-value-parser": "^4.2.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.2.0",
    "prisma-json-types-generator": "4.0.1",
    "prisma-openapi": "^1.3.6",
    "prisma-zod-generator": "^2.1.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "server-only": "^0.0.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^4.1.18",
    "terser": "^5.44.1",
    "ts-jest": "^29.4.6",
    "ts-prune": "^0.10.3",
    "tsx": "^4.21.0",
    "turbo": "^2.7.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.0",
    "vercel": "^50.1.3",
    "zod-openapi": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "tmp": "^0.2.3",
      "glob": ">=11.1.0",
      "js-yaml": ">=4.1.1",
      "rimraf": ">=5.0.0",
      "inflight": ">=2.0.0",
      "@types/react": "19.2.7",
      "@types/react-dom": "19.2.3",
      "undici@>=4.5.0 <5.28.5": ">=5.28.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "undici@<5.29.0": ">=5.29.0",
      "browserslist": "4.24.4",
      "@typescript-eslint/utils": "^8.48.1",
      "serialize-error-cjs": "^0.2.0",
      "del": ">=8.0.0",
      "got@<11.8.5": ">=11.8.5",
      "semver-regex@<3.1.3": ">=3.1.3",
      "semver-regex@<3.1.4": ">=3.1.4",
      "http-cache-semantics@<4.1.1": ">=4.1.1",
      "cross-spawn@<6.0.6": ">=6.0.6"
    },
    "ignoredBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@vercel/speed-insights",
      "esbuild",
      "inngest-cli",
      "lefthook",
      "prisma",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "msw",
      "prisma-zod-generator"
    ]
  },
  "dependencies": {
    "@prisma/client": "^7.2.0",
    "@zodios/core": "^10.9.6"
  }
}
