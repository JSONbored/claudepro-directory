{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./apps/web/*"],
      "@/src/*": ["./apps/web/src/*"]
    },
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "typeRoots": ["./node_modules/@types"],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/src/types/**/*.d.ts",
    "apps/web/.next/types/**/*.ts",
    "scripts/**/*.ts",
    "packages/web-runtime/src/**/*.ts",
    "packages/web-runtime/src/**/*.d.ts",
    "packages/shared-runtime/src/**/*.ts",
    "packages/data-layer/src/**/*.ts",
    "packages/generators/src/**/*.ts",
    "packages/database-types/**/*.ts",
    "packages/database-types/src/prisma-json-types.ts",
    "packages/cloudflare-runtime/src/**/*.ts",
    "apps/workers/**/src/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}
