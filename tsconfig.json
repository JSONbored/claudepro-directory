{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./config/tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./apps/web/*"],
      "@/src/*": ["./apps/web/src/*"]
    },
    "noEmit": true,
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo",
    "typeRoots": [
      "./node_modules/@types",
      "./packages/edge-runtime/src/types"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "apps/web/src/**/*.ts",
    "apps/web/src/**/*.tsx",
    "apps/web/src/types/**/*.d.ts",
    "apps/web/.next/types/**/*.ts",
    "scripts/**/*.ts",
    "packages/web-runtime/src/**/*.ts",
    "packages/web-runtime/src/**/*.d.ts",
    "packages/shared-runtime/src/**/*.ts",
    "packages/data-layer/src/**/*.ts",
    "packages/generators/src/**/*.ts",
    "packages/database-types/**/*.ts",
    "packages/database-types/src/prisma-json-types.ts",
    "packages/edge-runtime/src/types/**/*.d.ts",
    "types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tests",
    "vitest.config.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "apps/edge/functions",
    "packages/edge-runtime/src/utils/email",
    "packages/edge-runtime/src/utils/email/**",
    "packages/edge-runtime/src/utils/email/**/*",
    "packages/edge-runtime/src/app.ts",
    "packages/edge-runtime/src/utils/integrations/resend.ts",
    "packages/edge-runtime/src/utils/webhook/auth-hook.ts",
    "packages/edge-runtime/src/utils/email/digest-helpers.ts",
    "packages/edge-runtime/src/utils/email/sequence-helpers.ts"
  ]
}
