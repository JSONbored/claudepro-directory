{
  "name": "@heyclaude/shared-runtime",
  "version": "1.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schemas/env": {
      "types": "./dist/schemas/env.d.ts",
      "development": "./src/schemas/env.ts",
      "default": "./src/schemas/env.ts"
    },
    "./privacy.ts": {
      "types": "./dist/privacy.d.ts",
      "development": "./src/privacy.ts",
      "default": "./src/privacy.ts"
    },
    "./logger/config.ts": {
      "types": "./dist/logger/config.d.ts",
      "development": "./src/logger/config.ts",
      "default": "./src/logger/config.ts"
    },
    "./logger/index.ts": {
      "types": "./dist/logger/index.d.ts",
      "development": "./src/logger/index.ts",
      "default": "./src/logger/index.ts"
    },
    "./error-handling.ts": {
      "types": "./dist/error-handling.d.ts",
      "development": "./src/error-handling.ts",
      "default": "./src/error-handling.ts"
    },
    "./rate-limit": {
      "types": "./dist/rate-limit.d.ts",
      "development": "./src/rate-limit.ts",
      "default": "./src/rate-limit.ts"
    },
    "./proxy/guards": {
      "types": "./dist/proxy/guards.d.ts",
      "development": "./src/proxy/guards.ts",
      "default": "./src/proxy/guards.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "development": "./src/env.ts",
      "default": "./src/env.ts"
    },
    "./platform": {
      "types": "./dist/platform/index.d.ts",
      "development": "./src/platform/index.ts",
      "default": "./src/platform/index.ts"
    },
    "./utils/serialize": {
      "types": "./dist/utils/serialize.d.ts",
      "development": "./src/utils/serialize.ts",
      "default": "./src/utils/serialize.ts"
    },
    "./infisical": {
      "types": "./dist/infisical/client.d.ts",
      "development": "./src/infisical/client.ts",
      "default": "./src/infisical/client.ts"
    },
    "./infisical/cache": {
      "types": "./dist/infisical/cache.d.ts",
      "development": "./src/infisical/cache.ts",
      "default": "./src/infisical/cache.ts"
    },
    "./infisical/client": {
      "types": "./dist/infisical/client.d.ts",
      "development": "./src/infisical/client.ts",
      "default": "./src/infisical/client.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint --config eslint.config.mjs src --ignore-pattern '**/*.generated.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.ts'",
    "lint:fix": "eslint --config eslint.config.mjs src --ignore-pattern '**/*.generated.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.ts' --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@axiomhq/pino": "^1.3.1",
    "@heyclaude/database-types": "workspace:*",
    "@infisical/sdk": "^4.0.6",
    "@shikijs/transformers": "^3.20.0",
    "@supabase/supabase-js": "^2.89.0",
    "pino": "^10.1.0",
    "sanitize-html": "^2.17.0",
    "shiki": "^3.20.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/sanitize-html": "^2.16.0",
    "pino-pretty": "^13.1.3"
  }
}
