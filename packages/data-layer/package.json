{
  "name": "@heyclaude/data-layer",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./services/trending": {
      "development": "./src/services/trending.ts",
      "types": "./dist/services/trending.d.ts",
      "default": "./src/services/trending.ts"
    },
    "./prisma": {
      "development": "./src/prisma/index.ts",
      "types": "./dist/prisma/index.d.ts",
      "react-server": "./src/prisma/index.ts",
      "default": "./src/prisma/index.ts"
    },
    "./prisma/client": {
      "development": "./src/prisma/client.ts",
      "types": "./dist/prisma/client.d.ts",
      "react-server": "./src/prisma/client.ts",
      "default": "./src/prisma/client.ts"
    },
    "./utils/request-cache": {
      "development": "./src/utils/request-cache.ts",
      "types": "./dist/utils/request-cache.d.ts",
      "default": "./src/utils/request-cache.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint . --config ../../config/tools/eslint.config.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@heyclaude/database-types": "workspace:*",
    "@heyclaude/shared-runtime": "workspace:*",
    "@prisma/adapter-pg": "^7.2.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "typescript": "5.9.3"
  }
}
