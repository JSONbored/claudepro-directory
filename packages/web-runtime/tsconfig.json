{
  "extends": "../../config/tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "incremental": true,
    "tsBuildInfoFile": "./.tsbuildinfo",
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["next/types/global"],
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    { "path": "../database-types/tsconfig.json" },
    { "path": "../shared-runtime/tsconfig.json" },
    { "path": "../data-layer/tsconfig.json" },
    { "path": "../generators/tsconfig.json" }
  ]
}
