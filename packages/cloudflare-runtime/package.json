{
  "name": "@heyclaude/cloudflare-runtime",
  "version": "1.1.0",
  "private": true,
  "sideEffects": [
    "./src/prisma/node-globals-polyfill.ts"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config/env": {
      "types": "./dist/config/env.d.ts",
      "development": "./src/config/env.ts",
      "default": "./src/config/env.ts"
    },
    "./prisma/client": {
      "types": "./dist/prisma/client.d.ts",
      "development": "./src/prisma/client.ts",
      "default": "./src/prisma/client.ts"
    },
    "./auth/supabase": {
      "types": "./dist/auth/supabase.d.ts",
      "development": "./src/auth/supabase.ts",
      "default": "./src/auth/supabase.ts"
    },
    "./logging/pino": {
      "types": "./dist/logging/pino.d.ts",
      "development": "./src/logging/pino.ts",
      "default": "./src/logging/pino.ts"
    },
    "./utils/errors": {
      "types": "./dist/utils/errors.d.ts",
      "development": "./src/utils/errors.ts",
      "default": "./src/utils/errors.ts"
    },
    "./infisical/client": {
      "types": "./dist/infisical/client.d.ts",
      "development": "./src/infisical/client.ts",
      "default": "./src/infisical/client.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint . --config ../../.trunk/configs/eslint.config.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@heyclaude/database-types": "workspace:*",
    "@heyclaude/shared-runtime": "workspace:*",
    "@infisical/sdk": "^4.0.6",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@supabase/supabase-js": "^2.89.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251225.0",
    "@types/pg": "^8.16.0",
    "typescript": "5.9.3"
  }
}
