{
  "name": "@heyclaude/generators",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "heyclaude-generate-service-worker": "./src/bin/generate-service-worker.ts",
    "heyclaude-generate-skills": "./src/bin/generate-skills.ts",
    "heyclaude-generate-mcpb": "./src/bin/generate-mcpb.ts",
    "heyclaude-generate-readme": "./src/bin/generate-readme.ts",
    "heyclaude-cache": "./src/bin/cache.ts",
    "heyclaude-sync-db": "./src/bin/sync-db.ts",
    "heyclaude-lint-unused": "./src/bin/lint-unused.ts",
    "heyclaude-webhooks-replay": "./src/bin/replay-webhook.ts",
    "heyclaude-changelog": "./src/bin/changelog.ts",
    "heyclaude-analyze-dependencies": "./src/bin/analyze-dependencies.ts",
    "heyclaude-deploy-edge": "./src/bin/deploy-functions.ts",
    "heyclaude-sync-email": "./src/bin/sync-email-templates.ts",
    "heyclaude-generate-actions": "./src/bin/generate-server-actions.ts",
    "heyclaude-mcp-login": "./src/bin/mcp-login.ts",
    "heyclaude-bump-version": "./src/bin/bump-version.ts",
    "heyclaude-analyze-commits": "./src/bin/analyze-commits.ts",
    "heyclaude-extract-changelog-entry": "./src/bin/extract-changelog-entry.ts",
    "heyclaude-analyze-css": "./src/bin/analyze-css.ts",
    "heyclaude-migrate-theme": "./src/bin/migrate-theme.ts",
    "heyclaude-analyze-inline-styles": "./src/bin/analyze-inline-styles.ts",
    "heyclaude-consolidate-variables": "./src/bin/consolidate-variables.ts",
    "heyclaude-apply-variable-consolidation": "./src/bin/apply-variable-consolidation.ts",
    "heyclaude-comprehensive-css-analysis": "./src/bin/comprehensive-css-analysis.ts",
    "heyclaude-exhaustive-css-token-comparison": "./src/bin/exhaustive-css-token-comparison.ts",
    "heyclaude-migrate-inline-styles": "./src/bin/migrate-inline-styles.ts",
    "heyclaude-migrate-ui-classes": "./src/bin/migrate-ui-classes.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./toolkit/logger": "./src/toolkit/logger.ts",
    "./toolkit/env": "./src/toolkit/env.ts",
    "./toolkit/cache": "./src/toolkit/cache.ts",
    "./toolkit/supabase": "./src/toolkit/supabase.ts",
    "./toolkit/edge": "./src/toolkit/edge.ts",
    "./toolkit/mcp-token": "./src/toolkit/mcp-token.ts",
    "./commands/*": "./src/commands/*.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "type-check": "tsc --noEmit",
    "lint": "eslint --config eslint.config.mjs src --ignore-pattern '**/*.generated.ts' --ignore-pattern '**/*.test.ts' --ignore-pattern '**/*.spec.ts'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@heyclaude/database-types": "workspace:*",
    "@heyclaude/edge-runtime": "workspace:*",
    "@heyclaude/shared-runtime": "workspace:*",
    "@heyclaude/web-runtime": "workspace:*",
    "@iarna/toml": "^2.2.5",
    "@prisma/generator-helper": "^7.1.0",
    "@supabase/supabase-js": "^2.87.3",
    "archiver": "^7.0.1",
    "escape-html": "^1.0.3",
    "glob": "^13.0.0",
    "jiti": "^2.6.1",
    "open": "^11.0.0",
    "ora": "^9.0.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "postcss": "^8.5.6",
    "postcss-value-parser": "^4.2.0",
    "resend": "^6.6.0",
    "ts-morph": "^27.0.2",
    "zod": "^4.2.0",
    "zod-openapi": "^5.4.5"
  },
  "devDependencies": {
    "@types/escape-html": "^1.0.4",
    "@types/pg": "^8.16.0",
    "ts-morph": "^27.0.2"
  }
}
